@{
    ViewData["Title"] = "My Bookings (Parent)";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">My Bookings (Parent)</h3>
    </div>

    <div id="msg"></div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Status</label>
                    <select id="status" class="form-select">
                        <option value="">All</option>
                        <option value="Pending">Pending</option>
                        <option value="Accepted">Accepted</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button id="btnLoad" class="btn btn-primary w-100">Load</button>
                </div>
            </div>
        </div>
    </div>

    <div id="list"></div>
</div>

@section Scripts {
    <script>
        const API_ROOT = window.API_BASE || "";
        const token = (localStorage.getItem("jwt_token") || "").replace(/^"|"$/g, "");

        function setMsg(text, type) {
            if (!text) {
                $("#msg").html("");
                return;
            }

            let cls = "alert-info";
            if (type === "success") cls = "alert-success";
            else if (type === "error") cls = "alert-danger";
            else if (type === "warning") cls = "alert-warning";

            $("#msg").html(`<div class="alert ${cls}">${text}</div>`);
        }

        function authHeaders() {
            return token ? { Authorization: `Bearer ${token}` } : {};
        }

        function safeDate(v) {
            if (!v) return "-";
            return String(v).substring(0, 10);
        }

        function safeTime(v) {
            if (!v) return "-";
            return String(v).substring(0, 5);
        }

        function normalizeStatus(status) {
            if (status === null || status === undefined) return "";

            // string হলে
            if (typeof status === "string") {
                return status.trim().toLowerCase();
            }

            // number হলে enum mapping
            if (typeof status === "number") {
                switch (status) {
                    case 1: return "pending";
                    case 2: return "accepted";
                    case 3: return "rejected";
                    case 4: return "confirmed";
                    case 5: return "completed";
                    case 6: return "cancelled";
                    default: return String(status).toLowerCase();
                }
            }

            // object হলে common property handle
            if (typeof status === "object") {
                if (status.name) return String(status.name).trim().toLowerCase();
                if (status.value !== undefined) return normalizeStatus(status.value);
                return "";
            }

            return String(status).trim().toLowerCase();
        }

        function displayStatus(status) {
            const s = normalizeStatus(status);

            switch (s) {
                case "pending": return "Pending";
                case "accepted": return "Accepted";
                case "rejected": return "Rejected";
                case "confirmed": return "Confirmed";
                case "completed": return "Completed";
                case "cancelled":
                case "canceled": return "Cancelled";
                default: return status ?? "-";
            }
        }

        function badge(status) {
            const s = normalizeStatus(status);

            switch (s) {
                case "pending":
                    return `<span class="badge bg-warning text-dark">Pending</span>`;
                case "accepted":
                    return `<span class="badge bg-info text-dark">Accepted</span>`;
                case "rejected":
                    return `<span class="badge bg-danger">Rejected</span>`;
                case "confirmed":
                    return `<span class="badge bg-primary">Confirmed</span>`;
                case "completed":
                    return `<span class="badge bg-success">Completed</span>`;
                case "cancelled":
                case "canceled":
                    return `<span class="badge bg-secondary">Cancelled</span>`;
                default:
                    return `<span class="badge bg-light text-dark">${displayStatus(status)}</span>`;
            }
        }

        function actionHtml(b) {
            const status = normalizeStatus(b.status);
            const hasReview = b.hasReview === true;

            if (status === "completed" && !hasReview) {
                return `<a href="/Web/ReviewCreate/${b.id}" class="btn btn-sm btn-success">Write Review</a>`;
            }

            if (status === "completed" && hasReview) {
                return `<span class="badge bg-secondary">Reviewed</span>`;
            }

            return `<span class="text-muted">-</span>`;
        }

        function buildTable(items) {
            let html = `
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-bordered table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width:70px;">Id</th>
                                                <th style="width:120px;">Date</th>
                                                <th style="width:140px;">Time</th>
                                                <th style="width:120px;">Status</th>
                                                <th>Sitter</th>
                                                <th style="width:100px;">Rate</th>
                                                <th style="width:150px;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                    `;

            items.forEach(b => {
                const sitter = b.sitter || {};

                html += `
                            <tr>
                                <td>${b.id ?? "-"}</td>
                                <td>${safeDate(b.bookingDate)}</td>
                                <td>${safeTime(b.startTime)} - ${safeTime(b.endTime)}</td>
                                <td>${badge(b.status)}</td>
                                <td>
                                    <div class="fw-semibold">${sitter.fullName || "-"}</div>
                                    <div class="small text-muted">${sitter.email || ""}</div>
                                </td>
                                <td>${sitter.hourlyRate ?? "-"}</td>
                                <td>${actionHtml(b)}</td>
                            </tr>
                        `;
            });

            html += `
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    `;

            $("#list").html(html);
        }

        function loadBookings() {
            setMsg("", "");
            $("#list").html(`<div class="text-muted">Loading bookings...</div>`);

            if (!token) {
                $("#list").html("");
                setMsg("Please login first.", "error");
                return;
            }

            const st = $("#status").val();
            let url = `${API_ROOT}/api/my-bookings/parent?page=1&pageSize=50`;

            if (st) {
                url += `&status=${encodeURIComponent(st)}`;
            }

            $.ajax({
                url: url,
                method: "GET",
                headers: authHeaders()
            })
                .done(function(res) {
                    const items = res.items || [];

                    if (!items.length) {
                        $("#list").html(`<div class="alert alert-warning mb-0">No bookings found.</div>`);
                        return;
                    }

                    buildTable(items);
                })
                .fail(function(xhr) {
                    $("#list").html("");

                    if (xhr.status === 401) {
                        setMsg("Session expired. Please login again.", "error");
                    } else {
                        setMsg(xhr.responseText || "Failed to load bookings.", "error");
                    }
                });
        }

        $(document).ready(function() {
            $("#btnLoad").on("click", loadBookings);
            loadBookings();
        });
    </script>
}