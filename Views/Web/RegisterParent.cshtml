@{
    ViewData["Title"] = "Parent Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #F9E3DF, #F3C6C0);
        margin: 0;
    }

    .page-wrapper {
        height:auto;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .register-card {
        width:auto;
        min-width: 800px; 
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        padding: 20px;
    }

    .logo {
        width: 50px;
        height: 50px;
        object-fit: contain;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 7px 10px;
        font-size: 14px;
    }

    label {
        font-size: 18px;
        margin-bottom: 2px;
    }

    .btn {
        padding: 8px;
        font-size: 14px;
    }

    .error-text {
        color: red;
        font-size: 12px;
        display: none;
    }
</style>


<div class="page-wrapper">
    <div class="card register-card p-4">

        <!-- Logo + Title -->
        <div class="text-center mb-3">
            <img src="/images/logo.png"  alt="Logo" width="100" height="90" />
            <h5 class="mb-0">Parent Registration</h5>
            <small class="text-muted">Create your account</small>
        </div>

        <form id="registerForm">

            <div class="mb-2">
                <label>Full Name</label>
                <input type="text" class="form-control" placeholder="e.g. Md. Rahim Uddin" required>
            </div>

            <div class="mb-2">
                <label>NID No</label>
                <input type="text" class="form-control" placeholder="e.g. 1234567890" required>
            </div>

            <div class="mb-2">
                <label>Gender</label>
                <select class="form-select" required>
                    <option value=""> (Select)</option>
                    <option>Male</option>
                    <option>Female</option>
                    <option>Other</option>
                </select>
            </div>

            <div class="mb-2">
                <label>Date of Birth</label>
                <input type="date" class="form-control" required>
            </div>

            <div class="mb-2">
                <label>Address</label>
                <textarea class="form-control" rows="2" placeholder=" (e.g. House 12, Road 5, Dhaka)" required></textarea>
            </div>

            <div class="mb-2">
                <label>Email</label>
                <input type="" class="form-control" placeholder="Email (e.g. example@gmail.com)" required>
            </div>

            <div class="mb-2">
                <label>Phone No</label>
                <input type="text" class="form-control" placeholder=" (e.g. 017XXXXXXXX)" required>
            </div>

            <div class="mb-2">
                <label>Password</label>
                <input type="" id="password" class="form-control" placeholder="Password (min 6 characters)" required>
            </div>

            <div class="mb-1">
                <label>Confirm Password</label>
                <input type="password" id="" class="form-control" placeholder="Confirm Password" required>
                <div id="errorMsg" class="error-text">Password mismatch!</div>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between mt-3">
                <button type="submit" class="btn btn-dark btn-custom w-40">
                    Create Account
                </button>

                <button type="button" class="btn btn-outline-secondary ms-2" onclick="history.back()">
                    Back ⮜
                </button>  
            
            </div>

        </form>

    </div>
</div>

<script>
    const form = document.getElementById("registerForm");
    const password = document.getElementById("password");
    const confirmPassword = document.getElementById("confirmPassword");
    const errorMsg = document.getElementById("errorMsg");

    form.addEventListener("submit", function (e) {
        if (password.value !== confirmPassword.value) {
            e.preventDefault();
            errorMsg.style.display = "block";
        } else {
            errorMsg.style.display = "none";
        }
    });
</script>